# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Jupyter
*.ipynb

# Outputs (generated)
output/

# Real data (never commit)
Real_data/

# Spreadsheets: ignore by default
*.xlsx
*.xls
*.csv

# Allow anonymized samples ONLY under sample_data/
!sample_data/
!sample_data/**/*.xlsx
!sample_data/**/*.xls
!sample_data/**/*.csv